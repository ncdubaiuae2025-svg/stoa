{
  "name": "stoa",
  "version": "0.2.0",
  "description": "Solana-native multi-agent swarm framework with self-healing, quality scoring, and production-grade orchestration",
  "agents": [
    {
      "name": "scout",
      "role": "Onchain intelligence",
      "skills": ["scan-tokens", "morning-brief"]
    },
    {
      "name": "analyst",
      "role": "Signal processing",
      "skills": ["analyze-signal"]
    },
    {
      "name": "executor",
      "role": "Trade execution",
      "skills": ["execute-trade"]
    },
    {
      "name": "guardian",
      "role": "Risk management & swarm health",
      "skills": ["check-risk", "health-check", "self-repair", "self-improve", "cost-report"]
    }
  ],
  "skills": [
    "scan-tokens",
    "analyze-signal",
    "execute-trade",
    "check-risk",
    "morning-brief",
    "health-check",
    "self-repair",
    "self-improve",
    "cost-report"
  ],
  "chains": [
    "full-scan",
    "morning-pipeline",
    "weekly-maintenance"
  ],
  "features": [
    "self-healing",
    "quality-scoring",
    "skill-chaining",
    "deduplication",
    "rate-limiting",
    "output-validation",
    "token-tracking",
    "structured-logging",
    "security-scanning",
    "wallet-tracking",
    "webhook-triggers",
    "retry-backoff"
  ],
  "chain": "solana",
  "runtime": "github-actions",
  "license": "MIT"
}
